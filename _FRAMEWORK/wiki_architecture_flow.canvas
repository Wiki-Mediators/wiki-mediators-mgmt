		{"id":"git","type":"text","text":"# Git substrate\n\nLayer 2 records byte history.\n\nEverything derivable reads from committed files and Git metadata.","x":1040,"y":-410,"width":390,"height":180},
		{"id":"deriver-tools","type":"text","text":"# Layer 3 tools\n\ntools/wiki_deriver/build_vault_index.py\ntools/wiki_deriver/link_reference_checker.py\ntools/wiki_deriver/build_orientation_digest.py\ntools/wiki_deriver/derived_staleness_signal.py\n\nDumb rule: compute and flag; never fix.","x":560,"y":20,"width":440,"height":250},
		{"id":"derived","type":"text","text":"# _DERIVED outputs\n\n_DERIVED/vault_index.json/md\n_DERIVED/broken_links.md\n_DERIVED/orientation_digest.md\n_DERIVED/derived_staleness.json/md\n\nHuman/agent-readable views rebuilt from source.","x":1060,"y":20,"width":430,"height":230},
		{"id":"distill","type":"text","text":"# Layer 4: cold distillation\n\nOccasional future agent pass.\nReads committed source + derived views.\nWrites settled, cited notes back to the working vault.\n\nNot a constantly running tool.","x":1580,"y":20,"width":420,"height":220},
		{"id":"mgmt-tools","type":"text","text":"# Management bridge\n\ntools/management_bridge/build_management_vault.py\ntools/management_bridge/management_auto_sync.py\ntools/management_bridge/management_vault_config.json\n\nOne-way allow-listed clean subset.","x":560,"y":380,"width":440,"height":220},
		{"id":"mgmt-vault","type":"text","text":"# Management vault\n\nC:/VMShare/NT8lab_mgmt\n\nClean orchestrator-facing vault.\nPrivate GitHub / Claude project path.\nNo raw working-vault mirror.","x":1060,"y":380,"width":430,"height":210},
		{"id":"conv-archive","type":"text","text":"# Conversation archive\n\nC:/VMShare/conversation_archive\n\nRaw conversation/session tape.\nLocal-only. No remote.\nSearch cold when asked about prior discussions.","x":560,"y":700,"width":430,"height":210},
