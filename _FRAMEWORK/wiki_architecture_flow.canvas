		{"id":"mgmt-tools","type":"text","text":"# Management bridge\n\ntools/management_bridge/build_management_vault.py\ntools/management_bridge/management_auto_sync.py\ntools/management_bridge/management_vault_config.json\n\nOne-way allow-listed clean subset.\n\nAdjacent dumb tool: deps/tools/render_catalog.py renders dependency catalog from manifest.","x":340,"y":435,"width":440,"height":260},
