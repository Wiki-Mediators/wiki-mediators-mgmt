		{"id":"conv-archive","type":"text","text":"C:/VMShare/conversation_archive\n\nLocal-only raw archive.\nNot a source note until deliberately distilled or promoted.","x":-1160,"y":850,"width":520,"height":170},
		{"id":"capture-integrity","type":"file","file":"tools/wiki_deriver/capture_integrity_checker.py","x":1820,"y":250,"width":420,"height":170},
