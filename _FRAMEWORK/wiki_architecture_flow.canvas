	"nodes":[
		{"id":"title","type":"text","text":"# Wiki Architecture Flow\nZoomable Obsidian canvas.\n\nThe graph is: write -> record -> derive -> distill, with management and conversation archive as adjacent vaults.","x":-940,"y":-520,"width":520,"height":180},
