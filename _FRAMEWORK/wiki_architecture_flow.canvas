		{"id":"conv-archive","type":"text","text":"# Conversation archive\n\nC:/VMShare/conversation_archive\n\nRaw conversation/session tape.\nLocal-only. No remote.\nSearch cold when asked about prior discussions.","x":630,"y":760,"width":430,"height":210},
		{"id":"derived","type":"text","text":"# _DERIVED outputs\n\nvault_index\nbroken_links\norientation_digest\nderived_staleness\nsource_census\ntrigger_status\nsession_index\nretrieval_detector / term_cooccurrence\ntwo_lane_search_last\ncapture_integrity\n\nHuman/agent-readable views rebuilt from source.","x":1260,"y":-220,"width":430,"height":300},
		{"id":"distill","type":"text","text":"# Layer 4: cold distillation\n\nOccasional future agent pass.\nReads committed source + derived views.\nWrites settled, cited notes back to the working vault.\n\nNot a constantly running tool.","x":1155,"y":155,"width":420,"height":220},
		{"id":"mgmt-vault","type":"text","text":"# Management vault\n\nC:/VMShare/NT8lab_mgmt\n\nClean orchestrator-facing vault.\nPrivate GitHub / Claude project path.\nNo raw working-vault mirror.","x":1260,"y":565,"width":430,"height":210},
