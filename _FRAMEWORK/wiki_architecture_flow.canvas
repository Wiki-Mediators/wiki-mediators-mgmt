{
	"nodes":[
		{"id":"title","type":"text","text":"# Wiki Mediators Architecture\nZoomable working map for Obsidian.\n\nFlow: write -> record -> derive -> distill.\nAdjacent systems: management mirror + conversation archive.","x":-1160,"y":-760,"width":520,"height":180},
		{"id":"layer1-band","type":"text","text":"# Layer 1 — WRITE\nHumans and agents create source notes, reports, specs, code, and decisions.\n\nRule: write naturally; do not carry wiki-maintenance logic in your head.","x":-1160,"y":-500,"width":520,"height":180},
		{"id":"layer2-band","type":"text","text":"# Layer 2 — RECORD\nThe logger captures file changes into Git.\n\nRule: Git is substrate, not foreground work.","x":-520,"y":-500,"width":500,"height":180},
		{"id":"substrate-band","type":"text","text":"# Git substrate\nComplete byte history.\n\nDumb tools read committed/source files and Git metadata. Nothing replaces the vault as source of truth.","x":100,"y":-500,"width":520,"height":180},
		{"id":"layer3-band","type":"text","text":"# Layer 3 — DERIVE\nDeterministic tools compute indexes, reports, flags, search views, receipts, and dashboards.\n\nRule: compute and flag; never fix.","x":740,"y":-500,"width":560,"height":180},
		{"id":"layer4-band","type":"text","text":"# Layer 4 — DISTILL\nCold, occasional agent pass.\n\nReads committed source + derived views, then writes settled/cited notes back to Layer 1.","x":1440,"y":-500,"width":500,"height":180},
		{"id":"agents","type":"file","file":"AGENTS.md","x":-1160,"y":-240,"width":360,"height":170},
		{"id":"method","type":"file","file":"ninja-traitorate-methodology-reference.md","x":-1160,"y":-20,"width":360,"height":170},
		{"id":"altitude","type":"file","file":"_PROJECT_ALTITUDE_MAP.md","x":-1160,"y":200,"width":360,"height":170},
		{"id":"patterns","type":"file","file":"_FRAMEWORK/PATTERNS.md","x":-760,"y":-240,"width":360,"height":150},
		{"id":"ops","type":"file","file":"_FRAMEWORK/OPERATIONS.md","x":-760,"y":-40,"width":360,"height":150},
		{"id":"layer-arch","type":"file","file":"_FRAMEWORK/LAYER_ARCHITECTURE.md","x":-760,"y":160,"width":360,"height":150},
		{"id":"logger","type":"file","file":"tools/wiki_logger/wiki_logger.py","x":-520,"y":-160,"width":380,"height":170},
		{"id":"logger-config","type":"file","file":"tools/wiki_logger/wiki_logger.config.json","x":-520,"y":80,"width":380,"height":150},
		{"id":"logger-note","type":"text","text":"Logger daemon\n\nOnly always-running component.\nCaptures settled file states.\nGuardrails large-file commits.","x":-520,"y":290,"width":380,"height":150},
		{"id":"git","type":"text","text":"# .git history\n\nThe one substrate every layer can reread.\n\nCapture first, derive later.","x":100,"y":-160,"width":430,"height":170},
		{"id":"working-vault","type":"text","text":"# Working vault\nC:/VMShare/NT8lab\n\nSource notes, code, configs, reports, specs.\nThis is the durable truth.","x":100,"y":90,"width":430,"height":190},
		{"id":"roadmap","type":"file","file":"_FRAMEWORK/derived_layer_and_dumb_tool_roadmap.md","x":740,"y":-220,"width":420,"height":170},
		{"id":"runner","type":"file","file":"tools/wiki_deriver/run_derivers.py","x":1200,"y":-220,"width":420,"height":170},
		{"id":"runner-out","type":"file","file":"_DERIVED/derivers_last_run.md","x":1660,"y":-220,"width":420,"height":170},
		{"id":"deriver-tools","type":"text","text":"# Built wiki-deriver capabilities: 12\n\n1 vault index\n2 link checker\n3 orientation digest\n4 staleness signal\n5 source census\n6 trigger watcher\n7 session link index\n8 term co-occurrence\n9 retrieval detector\n10 vault/two-lane search\n11 capture integrity\n12 deriver runner","x":740,"y":30,"width":420,"height":360},
		{"id":"derived","type":"text","text":"# _DERIVED outputs\n\nvault_index\nbroken_links\norientation_digest\nderived_staleness\nsource_census\ntrigger_status\nsession_index\nretrieval_detector / term_cooccurrence\ntwo_lane_search_last\ncapture_integrity\nderivers_last_run\n\nRebuilt views, not source truth.","x":1200,"y":30,"width":420,"height":390},
		{"id":"distill","type":"text","text":"# Cold distillation\n\nFuture/occasional Layer 4 pass.\n\nUses derived views to decide what needs human-quality synthesis, then writes cited notes back into the vault.","x":1440,"y":520,"width":500,"height":220},
		{"id":"housekeeper","type":"text","text":"# Housekeeping agent (deferred)\n\nReads accumulated flags from Layer 3.\nMakes judgment calls dumb tools cannot make.\n\nStill not a daemon.","x":1440,"y":800,"width":500,"height":210},
		{"id":"management-band","type":"text","text":"# Adjacent: management mirror\nClean orchestrator-facing subset.\nOne-way bridge to private GitHub / Claude project.","x":100,"y":620,"width":520,"height":150},
		{"id":"mgmt-tools","type":"text","text":"tools/management_bridge/build_management_vault.py\ntools/management_bridge/management_auto_sync.py\nmanagement_vault_config.json\n\nSecret scan stays hard gate.","x":740,"y":620,"width":520,"height":170},
		{"id":"mgmt-vault","type":"text","text":"C:/VMShare/NT8lab_mgmt\n\nPrivate GitHub mirror.\nClaude project Sync reads from here.\nNo raw working-vault mirror.","x":740,"y":850,"width":520,"height":170},
		{"id":"archive-band","type":"text","text":"# Adjacent: conversation archive\nRaw session tape lives outside the working vault.\nSearch cold when asked about prior discussion.\nExtracts/scratch stay untracked.","x":-1160,"y":620,"width":520,"height":170},
		{"id":"conv-decision","type":"file","file":"_FRAMEWORK/conversation_archive_decision_record.md","x":-520,"y":620,"width":430,"height":160},
